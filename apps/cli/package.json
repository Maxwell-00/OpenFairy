{
  "name": "@fairy/cli",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "bin": {
    "fairy": "./dist/bin/fairy.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "doctor": "node ../../scripts/run-cli.mjs doctor",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:developer-preview": "vitest run test/developer-preview.test.ts --reporter verbose"
  },
  "dependencies": {
    "@fairy/artifacts": "workspace:*",
    "@fairy/config": "workspace:*",
    "@fairy/gateway": "workspace:*",
    "@fairy/kernel": "workspace:*",
    "@fairy/memory": "workspace:*",
    "@fairy/model-gateway": "workspace:*",
    "@fairy/perception": "workspace:*",
    "@fairy/protocol": "workspace:*",
    "@fairy/research": "workspace:*",
    "@fairy/voice": "workspace:*",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@fairy/testing": "workspace:*",
    "@types/ws": "^8.18.1"
  }
}
