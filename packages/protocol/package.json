{
  "name": "@fairy/protocol",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "generate:assets": "node ../../scripts/generate-protocol-assets.mjs",
    "generate:types": "node ../../scripts/generate-schema-types.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "ulid": "^3.0.1"
  }
}
