{
  "name": "@fairy/testing",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "scripts": {
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --reporter verbose",
    "test:voice-web-ptt": "vitest run test/voice.web-ptt.test.ts --reporter verbose",
    "test:voice-mimo-asr-provider": "vitest run test/voice.mimo-asr-provider.test.ts --reporter verbose",
    "test:voice-worker-process": "vitest run test/voice.worker-process.test.ts --reporter verbose",
    "test:voice-tts-provider": "vitest run test/voice.tts-provider.test.ts --reporter verbose"
  },
  "dependencies": {
    "@fairy/artifacts": "workspace:*",
    "@fairy/config": "workspace:*",
    "@fairy/kernel": "workspace:*",
    "@fairy/memory": "workspace:*",
    "@fairy/model-gateway": "workspace:*",
    "@fairy/protocol": "workspace:*",
    "@fairy/research": "workspace:*",
    "@fairy/voice": "workspace:*",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@types/ws": "^8.18.1"
  }
}
